# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=pddikti_user
DB_PASSWORD=your_password_here
DB_NAME=pddikti_explorer

# JWT Secret
JWT_SECRET=change-this-to-a-very-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Auto-logout inactivity (seconds) - 30 minutes
INACTIVITY_TIMEOUT=1800

# Admin default credentials (only used for initial setup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
